    "@radix-ui/react-toast": "^1.2.15",
    "@tanstack/react-query": "^5.84.1",
    "@types/bcryptjs": "^3.0.0",
    "axios": "^1.11.0",
    "bcryptjs": "^3.0.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
